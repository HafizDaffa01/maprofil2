tyle=\"color:rgb(199, 146, 234)\">;</span><span class=\"token plain\"></span></span></div><div class=\"table-row\" style=\"color:#d6deeb\"><span class=\"table-cell select-none pr-4 text-right text-[10px] text-white/15\">08</span><span class=\"table-cell\"><span class=\"token plain\">var c </span><span class=\"token operator\" style=\"color:rgb(127, 219, 202)\">=</span><span class=\"token plain\"> math</span><span class=\"token punctuation\" style=\"color:rgb(199, 146, 234)\">.</span><span class=\"token function\" style=\"color:rgb(130, 170, 255)\">complex</span><span class=\"token punctuation\" style=\"color:rgb(199, 146, 234)\">(</span><span class=\"token number\" style=\"color:rgb(247, 140, 108)\">3</span><span class=\"token punctuation\" style=\"color:rgb(199, 146, 234)\">,</span><span class=\"token plain\"> </span><span class=\"token number\" style=\"color:rgb(247, 140, 108)\">4</span><span class=\"token punctuation\" style=\"color:rgb(199, 146, 234)\">)</span><span class=\"token punctuation\" style=\"color:rgb(199, 146, 234)\">;</span><span class=\"token plain\"></span></span></div><div class=\"table-row\" style=\"color:#d6deeb\"><span class=\"table-cell select-none pr-4 text-right text-[10px] text-white/15\">09</span><span class=\"table-cell\"><span class=\"token plain\">io</span><span class=\"token punctuation\" style=\"color:rgb(199, 146, 234)\">.</span><span class=\"token class-name\" style=\"color:rgb(255, 203, 139)\">Terminal</span><span class=\"token punctuation\" style=\"color:rgb(199, 146, 234)\">.</span><span class=\"token class-name\" style=\"color:rgb(255, 203, 139)\">Out</span><span class=\"token plain\"> </span><span class=\"token operator\" style=\"color:rgb(127, 219, 202)\">&lt;&lt;</span><span class=\"token plain\"> </span><span class=\"token string\" style=\"color:rgb(173, 219, 103)\">&quot;Absolute value of c: &quot;</span><span class=\"token plain\"></span></span></div><div class=\"table-row\" style=\"color:#d6deeb\"><span class=\"table-cell