\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><rect width=\"20\" height=\"16\" x=\"2\" y=\"4\" rx=\"2\"></rect><path d=\"m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7\"></path></svg>email</button><button type=\"button\" tabindex=\"0\" data-slot=\"button\" class=\"group/button inline-flex shrink-0 items-center justify-center border bg-clip-padding font-medium whitespace-nowrap outline-none select-none focus-visible:border-ring focus-visible:ring-3 focus-visible:ring-ring/50 active:not-aria-[haspopup]:translate-y-px disabled:pointer-events-none disabled:opacity-50 aria-invalid:border-destructive aria-invalid:ring-3 aria-invalid:ring-destructive/20 dark:aria-invalid:border-destructive/50 dark:aria-invalid:ring-destructive/40 [&amp;_svg]:pointer-events-none [&amp;_svg]:shrink-0 [&amp;_svg:not([class*=&#x27;size-&#x27;])]:size-4 bg-background hover:bg-muted aria-expanded:bg-muted aria-expanded:text-foreground dark:border-input dark:bg-input/30 dark:hover:bg-input/50 h-9 has-data-[icon=inline-end]:pr-2 has-data-[icon=inline-start]:pl-2 group gap-2 px-6 rounded-sm border-white/10 text-muted-foreground transition-all duration-300 text-xs uppercase tracking-wider hover:text-tui-orange hover:border-tui-orange/40 hover:shadow-[0_0_15px_rgba(249,115,22,0.1)] hover:scale-[1.02] active:scale-[0.98]\"><svg class=\"size-3.5\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><rect width=\"20\" height=\"20\" x=\"2\" y=\"2\" rx=\"5\" ry=\"5\"></rect><path d=\"M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z\"></path><line x1=\"17.5\" x2=\"17.51\" y1=\"6.5\" y2=\"6.5\"></line></svg>instagram</button></div></div></div></div><div class=\"hidden lg:flex w-[45%] h-screen items-center justify-center relative px-8\"><div class=\"w-full max-w-[320px]\" style=\"opacity:0\"><!--$--><!--$!--><template data-dgst=\"BAILOUT_TO_CLIENT_SIDE_RENDERING\"></template><!--/$--><!--/$--></div></div></div><div class=\"absolute bottom-8 left-1/2 z-20 -translate-x-1/2\" style=\"opacity:0\"><div class=\"flex flex-col items-center gap-1 text-muted-foreground/20\"><span class=\"text-[10px] uppercase tracking-widest\">scroll</span><span class=\"text-xs\">v</span></div></div></section><section id=\"about\" class=\"relative section-py\"><div class=\"section-px\"><div class=\"mx-auto max-w-5xl\"><div class=\"grid gap-12 lg:grid-cols-[1.2fr_1fr] lg:items-start\"><div style=\"opacity:0;transform:translateY(16px)\"><p class=\"mb-3 text-[11px] text-tui-cyan/70 font-medium\">[01] about</p><h2 class=\"mb-6 text-3xl font-bold tracking-tight text-foreground sm:text-4xl\">About Me</h2><div class=\"space-y-4 text-sm leading-relaxed text-muted-foreground/60\"><p>Full-Stack Developer &amp; Systems Engineer with a deep passion for low-level architecture and scalable infrastructure. Having managed real-world VPS environments, I bridge the gap between high-level web applications and the underlying hardware systems.</p><p>Currently building Sulfur++, a performance-oriented programming language, while exploring the frontiers of Agentic AI and Quantum Computing. Founder of The Tinker&#x27;s.</p></div><div class=\"mt-8\"><p class=\"mb-3 text-[10px] text-muted-foreground/40 uppercase tracking-wider\">current exploration</p><div class=\"space-y-3\"><div class=\"flex items-start gap-3\" style=\"opacity:0;transform:translateX(-8px)\"><span class=\"mt-0.5 text-tui-cyan/60 text-xs\">+</span><span class=\"text-sm text-foreground/60\">Systems Programming &amp; Compiler Design (Sulfur++)</span></div><div class=\"flex items-start gap-3\" style=\"opacity:0;transform:translateX(-8px)\"><span class=\"mt-0.5 text-tui-cyan/60 text-xs\">+</span><span class=\"text-sm text-foreground/60\">AI/ML Integration &amp; Agentic Systems</span></div><div class=\"flex items-start gap-3\" style=\"opacity:0;transform:translateX(-8px)\"><span class=\"mt-0.5 text-tui-cyan/60 text-xs\">+</span><span class=\"text-sm text-foreground/60\">Quantum Computing Theory &amp; Physics</span></div></div></div></div><div style=\"opacity:0;transform:translateY(16px)\"><div class=\"tui-panel tui-corners\"><div class=\"tui-panel-header\"><span class=\"text-[10px] text-muted-foreground/40\">profile</span></div><div class=\"grid grid-cols-2 divide-x divide-y divide-white/[0.04]\"><div class=\"p-5\"><p class=\"text-2xl font-bold text-foreground/80 tabular-nums\">7+</p><p class=\"mt-1 text-[10px] text-muted-foreground/40 uppercase tracking-wider\">languages</p></div><div class=\"p-5\"><p class=\"text-2xl font-bold text-foreground/80 tabular-nums\">12+</p><p class=\"mt-1 text-[10px] text-muted-foreground/40 uppercase tracking-wider\">projects</p></div><div class=\"p-5\"><p class=\"text-2xl font-bold text-foreground/80 tabular-nums\">4</p><p class=\"mt-1 text-[10px] text-muted-foreground/40 uppercase tracking-wider\">competitions</p></div><div class=\"p-5\"><p class=\"text-2xl font-bold text-foreground/80 tabular-nums\">2yr</p><p class=\"mt-1 text-[10px] text-muted-foreground/40 uppercase tracking-wider\">experience</p></div></div></div></div></div></div></div></section><section id=\"experience\" class=\"relative section-py\"><div class=\"section-px\"><div class=\"mx-auto max-w-3xl\"><div class=\"mb-16\" style=\"opacity:0;transform:translateY(12px)\"><p class=\"mb-3 text-[11px] text-tui-orange/70 font-medium\">[02] experience</p><h2 class=\"text-3xl font-bold tracking-tight text-foreground sm:text-4xl\">Work</h2></div><div class=\"flex flex-col gap-px bg-white/[0.03]\"><div class=\"group bg-card p-6 transition-all duration-200 hover:bg-[#1a1a1a]\" style=\"opacity:0;transform:translateY(12px)\"><div class=\"mb-3 flex items-baseline justify-between gap-4\"><h3 class=\"text-sm font-medium text-foreground/80\">Freelance Web Developer &amp; System Administrator</h3><span class=\"shrink-0 text-[10px] text-muted-foreground/35 tabular-nums\">2025 — Present</span></div><p class=\"mb-4 text-sm leading-relaxed text-muted-foreground/50\">Managed end-to-end web deployment, including VPS configuration, database optimization, and routine system maintenance.</p><div class=\"flex items-center gap-2 flex-wrap\"><span class=\"px-2 py-0.5 text-[10px] text-tui-cyan/60 bg-tui-cyan/[0.06] rounded-sm\">Linux Server</span><span class=\"px-2 py-0.5 text-[10px] text-tui-cyan/60 bg-tui-cyan/[0.06] rounded-sm\">MySQL</span><span class=\"px-2 py-0.5 text-[10px] text-tui-cyan/60 bg-tui-cyan/[0.06] rounded-sm\">NGINX</span><span class=\"px-2 py-0.5 text-[10px] text-tui-cyan/60 bg-tui-cyan/[0.06] rounded-sm\">Laravel</span></div></div><div class=\"group bg-card p-6 transition-all duration-200 hover:bg-[#1a1a1a]\" style=\"opacity:0;transform:translateY(12px)\"><div class=\"mb-3 flex items-baseline justify-between gap-4\"><h3 class=\"text-sm font-medium text-foreground/80\">IoT &amp; Embedded Systems Developer</h3><span class=\"shrink-0 text-[10px] text-muted-foreground/35 tabular-nums\">2025 — Present</span></div><p class=\"mb-4 text-sm leading-relaxed text-muted-foreground/50\">Designed and built IoT solutions using ESP32 and Arduino platforms. Developed sensor networks, GPS tracking systems, and automated control systems for real-world applications.</p><div class=\"flex items-center gap-2 flex-wrap\"><span class=\"px-2 py-0.5 text-[10px] text-tui-cyan/60 bg-tui-cyan/[0.06] rounded-sm\">C++</span><span class=\"px-2 py-0.5 text-[10px] text-tui-cyan/60 bg-tui-cyan/[0.06] rounded-sm\">ESP32</span><span class=\"px-2 py-0.5 text-[10px] text-tui-cyan/60 bg-tui-cyan/[0.06] rounded-sm\">Arduino</span><span class=\"px-2 py-0.5 text-[10px] text-tui-cyan/60 bg-tui-cyan/[0.06] rounded-sm\">RTOS</span><span class=\"px-2 py-0.5 text-[10px] text-tui-cyan/60 bg-tui-cyan/[0.06] rounded-sm\">IoT</span></div></div><div class=\"group bg-card p-6 transition-all duration-200 hover:bg-[#1a1a1a]\" style=\"opacity:0;transform:translateY(12px)\"><div class=\"mb-3 flex items-baseline justify-between gap-4\"><h3 class=\"text-sm font-medium text-foreground/80\">Full-Stack Web Developer</h3><span class=\"shrink-0 text-[10px] text-muted-foreground/35 tabular-nums\">2025 — Present</span></div><p class=\"mb-4 text-sm leading-relaxed text-muted-foreground/50\">Built and deployed modern web applications using React, Next.js, and TypeScript. Focused on performance, accessibility, and clean architecture.</p><div class=\"flex items-center gap-2 flex-wrap\"><span class=\"px-2 py-0.5 text-[10px] text-tui-cyan/60 bg-tui-cyan/[0.06] rounded-sm\">React</span><span class=\"px-2 py-0.5 text-[10px] text-tui-cyan/60 bg-tui-cyan/[0.06] rounded-sm\">Next.js</span><span class=\"px-2 py-0.5 text-[10px] text-tui-cyan/60 bg-tui-cyan/[0.06] rounded-sm\">TypeScript</span><span class=\"px-2 py-0.5 text-[10px] text-tui-cyan/60 bg-tui-cyan/[0.06] rounded-sm\">Tailwind CSS</span><span class=\"px-2 py-0.5 text-[10px] text-tui-cyan/60 bg-tui-cyan/[0.06] rounded-sm\">Node.js</span></div></div><div class=\"group bg-card p-6 transition-all duration-200 hover:bg-[#1a1a1a]\" style=\"opacity:0;transform:translateY(12px)\"><div class=\"mb-3 flex items-baseline justify-between gap-4\"><h3 class=\"text-sm font-medium text-foreground/80\">Systems Programming &amp; Language Design</h3><span class=\"shrink-0 text-[10px] text-muted-foreground/35 tabular-nums\">2024 — Present</span></div><p class=\"mb-4 text-sm leading-relaxed text-muted-foreground/50\">Developed Sulfur++, a programming language built on LLVM with AOT and JIT compiler pipelines. Explored compiler architecture, code generation, and language design principles.</p><div class=\"flex items-center gap-2 flex-wrap\"><span class=\"px-2 py-0.5 text-[10px] text-tui-cyan/60 bg-tui-cyan/[0.06] rounded-sm\">C++</span><span class=\"px-2 py-0.5 text-[10px] text-tui-cyan/60 bg-tui-cyan/[0.06] rounded-sm\">LLVM</span><span class=\"px-2 py-0.5 text-[10px] text-tui-cyan/60 bg-tui-cyan/[0.06] rounded-sm\">Compiler Design</span><span class=\"px-2 py-0.5 text-[10px] text-tui-cyan/60 bg-tui-cyan/[0.06] rounded-sm\">Assembly</span></div></div></div></div></div></section><section id=\"sulfur\" class=\"relative section-py\"><div class=\"section-px\"><div class=\"mx-auto max-w-5xl\"><div class=\"mb-16\" style=\"opacity:0;transform:translateY(20px)\"><p class=\"mb-3 text-[11px] text-tui-orange/70 font-medium\">[02] featured project</p><h2 class=\"mb-2 text-3xl font-bold tracking-tight text-foreground sm:text-4xl\">Sulfur++</h2><p class=\"mb-6 text-xs text-muted-foreground/50\">write easy, perform fast</p><p class=\"max-w-2xl text-sm leading-relaxed text-muted-foreground/60\">An interpreted programming language built on the LLVM infrastructure with a JIT compiler pipeline. Designed for systems programming with modern syntax.</p></div><div class=\"grid gap-6 lg:grid-cols-2 mb-16\"><div class=\"tui-panel\" style=\"opacity:0;transform:translateY(16px)\"><div class=\"tui-panel-header\"><span class=\"text-[10px] text-tui-orange/60\">The Problem</span></div><div class=\"p-5\"><p class=\"text-sm leading-relaxed text-muted-foreground/55\">Existing systems languages like C/C++ and Rust have steep learning curves, complex syntax, and error-prone manual memory management. Developers shouldn&#x27;t have to choose between performance and productivity.</p></div></div><div class=\"tui-panel\" style=\"opacity:0;transform:translateY(16px)\"><div class=\"tui-panel-header\"><span class=\"text-[10px] text-tui-green/60\">The Solution</span></div><div class=\"p-5\"><p class=\"text-sm leading-relaxed text-muted-foreground/55\">Sulfur++ combines modern, readable syntax with full systems-level control. Write expressive code that runs fast via LLVM-powered interpretation — getting both developer productivity and near-native performance.</p></div></div></div><div class=\"mb-16\" style=\"opacity:0;transform:translateY(16px)\"><p class=\"mb-6 text-[10px] text-muted-foreground/40 uppercase tracking-wider\">interpreter pipeline</p><div class=\"tui-panel\"><div class=\"flex items-center justify-between gap-0 overflow-x-auto\"><div class=\"flex flex-col items-center gap-2 py-6 px-4 min-w-[100px]\"><div class=\"flex size-10 items-center justify-center border border-tui-orange/20 bg-tui-orange/[0.04] text-tui-orange text-xs font-bold\">01</div><div class=\"text-center\"><p class=\"text-xs font-medium text-foreground/70\">Source Code</p><p class=\"text-[9px] text-muted-foreground/35 mt-0.5\">.sfpp</p></div></div><div class=\"flex items-center text-tui-orange/25 text-xs shrink-0\">&gt;&gt;</div><div class=\"flex flex-col items-center gap-2 py-6 px-4 min-w-[100px]\"><div class=\"flex size-10 items-center justify-center border border-tui-orange/20 bg-tui-orange/[0.04] text-tui-orange text-xs font-bold\">02</div><div class=\"text-center\"><p class=\"text-xs font-medium text-foreground/70\">Lexer</p><p class=\"text-[9px] text-muted-foreground/35 mt-0.5\">tokenize</p></div></div><div class=\"flex items-center text-tui-orange/25 text-xs shrink-0\">&gt;&gt;</div><div class=\"flex flex-col items-center gap-2 py-6 px-4 min-w-[100px]\"><div class=\"flex size-10 items-center justify-center border border-tui-orange/20 bg-tui-orange/[0.04] text-tui-orange text-xs font-bold\">03</div><div class=\"text-center\"><p class=\"text-xs font-medium text-foreground/70\">Parser</p><p class=\"text-[9px] text-muted-foreground/35 mt-0.5\">AST</p></div></div><div class=\"flex items-center text-tui-orange/25 text-xs shrink-0\">&gt;&gt;</div><div class=\"flex flex-col items-center gap-2 py-6 px-4 min-w-[100px]\"><div class=\"flex size-10 items-center justify-center border border-tui-orange/20 bg-tui-orange/[0.04] text-tui-orange text-xs font-bold\">04</div><div class=\"text-center\"><p class=\"text-xs font-medium text-foreground/70\">Interpreter</p><p class=\"text-[9px] text-muted-foreground/35 mt-0.5\">execute</p></div></div></div></div></div><div class=\"grid gap-12 lg:grid-cols-[1fr_1.2fr] lg:items-start\"><div class=\"flex flex-col gap-8\" style=\"opacity:0;transform:translateY(20px)\"><div class=\"flex flex-col gap-4\"><div class=\"flex items-start gap-3\" style=\"opacity:0;transform:translateX(-8px)\"><span class=\"mt-0.5 text-tui-orange/60 text-xs\">+</span><div><p class=\"mb-0.5 text-sm font-medium text-foreground/70\">LLVM Backend</p><p class=\"text-xs text-muted-foreground/45\">Optimized machine code generation</p></div></div><div class=\"flex items-start gap-3\" style=\"opacity:0;transform:translateX(-8px)\"><span class=\"mt-0.5 text-tui-orange/60 text-xs\">+</span><div><p class=\"mb-0.5 text-sm font-medium text-foreground/70\">JIT Compiler</p><p class=\"text-xs text-muted-foreground/45\">Runtime performance optimization</p></div></div><div class=\"flex items-start gap-3\" style=\"opacity:0;transform:translateX(-8px)\"><span class=\"mt-0.5 text-tui-orange/60 text-xs\">+</span><div><p class=\"mb-0.5 text-sm font-medium text-foreground/70\">Systems-Level</p><p class=\"text-xs text-muted-foreground/45\">Manual memory, zero-cost abstractions</p></div></div></div><button type=\"button\" tabindex=\"0\" data-slot=\"button\" class=\"group/button inline-flex shrink-0 items-center justify-center border bg-clip-padding font-medium whitespace-nowrap outline-none select-none focus-visible:border-ring focus-visible:ring-3 focus-visible:ring-ring/50 active:not-aria-[haspopup]:translate-y-px disabled:pointer-events-none disabled:opacity-50 aria-invalid:border-destructive aria-invalid:ring-3 aria-invalid:ring-destructive/20 dark:aria-invalid:border-destructive/50 dark:aria-invalid:ring-destructive/40 [&amp;_svg]:pointer-events-none [&amp;_svg]:shrink-0 [&amp;_svg:not([class*=&#x27;size-&#x27;])]:size-4 bg-background hover:bg-muted aria-expanded:bg-muted aria-expanded:text-foreground dark:border-input dark:bg-input/30 dark:hover:bg-input/50 h-9 px-2.5 has-data-[icon=inline-end]:pr-2 has-data-[icon=inline-start]:pl-2 w-fit gap-2 rounded-sm border-white/10 text-muted-foreground transition-all duration-300 text-xs uppercase tracking-wider hover:text-tui-orange hover:border-tu