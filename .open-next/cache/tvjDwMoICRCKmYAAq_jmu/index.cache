{"type":"app","meta":{"headers":{"x-nextjs-stale-time":"300","x-nextjs-prerender":"1","x-next-cache-tags":"_N_T_/layout,_N_T_/page,_N_T_/,_N_T_/index"},"segmentPaths":["/_tree","/_full","/__PAGE__","/_index","/_head"]},"html":"<!DOCTYPE html><html lang=\"en\" class=\"geist_mono_8d43a2aa-module__8Li5zG__variable dark h-full antialiased\"><head><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link rel=\"preload\" href=\"/_next/static/media/797e433ab948586e-s.p.0r6juujl39pe6.woff2\" as=\"font\" crossorigin=\"\" type=\"font/woff2\"/><link rel=\"preload\" as=\"image\" href=\"/the_tinkers.png\"/><link rel=\"stylesheet\" href=\"/_next/static/chunks/07u4r_zcr4wo1.css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/10qmq145gw9g7.js\"/><script src=\"/_next/static/chunks/3t7w6fh49ggh3.js\" async=\"\"></script><script src=\"/_next/static/chunks/3rxl-jt3pdxgx.js\" async=\"\"></script><script src=\"/_next/static/chunks/turbopack-23eythn5003ju.js\" async=\"\"></script><script src=\"/_next/static/chunks/2t9m8gckern4c.js\" async=\"\"></script><script src=\"/_next/static/chunks/158myu8e_yme3.js\" async=\"\"></script><script src=\"/_next/static/chunks/40gnprg50w4oj.js\" async=\"\"></script><script src=\"/_next/static/chunks/42iedd0abgpt-.js\" async=\"\"></script><script src=\"/_next/static/chunks/32fkiibbf8ztq.js\" async=\"\"></script><script src=\"/_next/static/chunks/35ld07q3nx2py.js\" async=\"\"></script><meta name=\"next-size-adjust\" content=\"\"/><title>~/Daffa</title><meta name=\"description\" content=\"Portfolio of Hafiz Daffa W. (HDW) — full-stack developer, systems programmer, and tech enthusiast.\"/><link rel=\"icon\" href=\"/favicon.ico?favicon.2vob68tjqpejf.ico\" sizes=\"256x256\" type=\"image/x-icon\"/><script src=\"/_next/static/chunks/0cz1d0mv5g_q7.js\" noModule=\"\"></script></head><body class=\"min-h-full flex flex-col\"><div hidden=\"\"><!--$--><!--/$-