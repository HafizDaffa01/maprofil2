pace-nowrap outline-none select-none focus-visible:border-ring focus-visible:ring-3 focus-visible:ring-ring/50 active:not-aria-[haspopup]:translate-y-px disabled:pointer-events-none disabled:opacity-50 aria-invalid:border-destructive aria-invalid:ring-3 aria-invalid:ring-destructive/20 dark:aria-invalid:border-destructive/50 dark:aria-invalid:ring-destructive/40 [&amp;_svg]:pointer-events-none [&amp;_svg]:shrink-0 [&amp;_svg:not([class*=&#x27;size-&#x27;])]:size-4 bg-background hover:bg-muted aria-expanded:bg-muted aria-expanded:text-foreground dark:border-input dark:bg-input/30 dark:hover:bg-input/50 h-9 has-data-[icon=inline-end]:pr-2 has-data-[icon=inline-start]:pl-2 group gap-2 px-4 rounded-sm border-white/10 text-muted-foreground transition-all duration-300 text-xs uppercase tracking-wider hover:text-tui-orange hover:border-tui-orange/40 hover:shadow-[0_0_15px_rgba(249,115,22,0.1)] hover:scale-[1.02] active:scale-[0.98] w-full justify-center\"><svg class=\"size-3.5\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><rect width=\"20\" height=\"20\" x=\"2\" y=\"2\" rx=\"5\" ry=\"5\"></rect><path d=\"M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z\"></path><line x1=\"17.5\" x2=\"17.51\" y1=\"6.5\" y2=\"6.5\"></line></svg>instagram</button></div></div></div></div><div class=\"w-full px-4 pb-12\"><div class=\"w-full max-w-[280px] mx-auto\" style=\"opacity:0\"><!--$--><!--$!--><template data-dgst=\"BAILOUT_TO_CLIENT_SIDE_RENDERING\"></template><!--/$--><!--/$--></div></div><div class=\"absolute bottom-6 left-1/2 z-20 -translate-x-1/2\" style=\"opacity:0\"><div class=\"flex flex-col items-center gap-1 text-muted-foreground/20\"><span class=\"text-[10px] uppercase tracking-widest\">scroll</span><svg class=\"size-4\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"6 9 12 15 18 9\"></polyline></svg></div></div></div></section><section id=\"about\" class=\"relative section-py\"><div class=\"section-px\"><div class=\"mx-auto max-w-full\"><div style=\"opacity:0;transform:translateY(16px)\"><p class=\"mb-3 text-[10px] text-tui-cyan/70 font-medium\">[01] about</p><h2 class=\"mb-4 text-2xl font-bold tracking-tight text-foreground\">About Me</h2><div class=\"space-y-3 text-sm leading-relaxed text-muted-foreground/60 mb-8\"><p>Full-Stack Developer &amp; Systems Engineer with a deep passion for low-level architecture and scalable infrastructure. Having managed real-world VPS environments, I bridge the gap between high-level web applications and the underlying hardware systems.</p><p>Currently building Sulfur++, a performance-oriented programming language, while exploring the frontiers of Agentic AI and Quantum Computing. Founder of The Tinker&#x27;s.</p></div><div class=\"mb-8\"><p class=\"mb-3 text-[9px] text-muted-foreground/40 uppercase tracking-wider\">current exploration</p><div class=\"space-y-2\"><div class=\"flex items-start gap-2\" style=\"opacity:0;transform:translateX(-6px)\"><span class=\"mt-0.5 text-tui-cyan/60 text-[10px]\">+</span><span class=\"text-[12px] text-foreground/60\">Systems Programming &amp; Compiler Design (Sulfur++)</span></div><div class=\"flex items-start gap-2\" style=\"opacity:0;transform:translateX(-6px)\"><span class=\"mt-0.5 text-tui-cyan/60 text-[10px]\">+</span><span class=\"text-[12px] text-foreground/60\">AI/ML Integration &amp; Agentic Systems</span></div><div class=\"flex items-start gap-2\" style=\"opacity:0;transform:translateX(-6px)\"><span class=\"mt-0.5 text-tui-cyan/60 text-[10px]\">+</span><span class=\"text-[12px] text-foreground/60\">Quantum Computing Theory &amp; Physics</span></div></div></div></div><div style=\"opacity:0;transform:translateY(16px)\"><div class=\"tui-panel\"><div class=\"tui-panel-header\"><span class=\"text-[9px] text-muted-foreground/40\">profile</span></div><div class=\"grid grid-cols-2 divide-x divide-y divide-white/[0.04]\"><div class=\"p-4\"><p class=\"text-xl font-bold text-foreground/80 tabular-nums\">7+</p><p class=\"mt-1 text-[9px] text-muted-foreground/40 uppercase tracking-wider\">languages</p></div><div class=\"p-4\"><p class=\"text-xl font-bold text-foreground/80 tabular-nums\">12+</p><p class=\"mt-1 text-[9px] text-muted-foreground/40 uppercase tracking-wider\">projects</p></div><div class=\"p-4\"><p class=\"text-xl font-bold text-foreground/80 tabular-nums\">4</p><p class=\"mt-1 text-[9px] text-muted-foreground/40 uppercase tracking-wider\">competitions</p></div><div class=\"p-4\"><p class=\"text-xl font-bold text-foreground/80 tabular-nums\">2yr</p><p class=\"mt-1 text-[9px] text-muted-foreground/40 uppercase tracking-wider\">experience</p></div></div></div></div></div></div></section><section id=\"experience\" class=\"relative section-py\"><div class=\"section-px\"><div class=\"mx-auto max-w-full\"><div class=\"mb-8\" style=\"opacity:0;transform:translateY(12px)\"><p class=\"mb-2 text-[10px] text-tui-orange/70 font-medium\">[02] experience</p><h2 class=\"text-2xl font-bold tracking-tight text-foreground\">Work</h2></div><div class=\"flex flex-col gap-2 bg-white/[0.03]\"><div class=\"group bg-card p-4 transition-all duration-200 hover:bg-[#1a1a1a]\" style=\"opacity:0;transform:translateY(12px)\"><div class=\"mb-2 flex items-baseline justify-between gap-2\"><h3 class=\"text-sm font-medium text-foreground/80\">Freelance Web Developer &amp; System Administrator</h3><span class=\"shrink-0 text-[9px] text-muted-foreground/35 tabular-nums\">2025 — Present</span></div><p class=\"mb-3 text-xs leading-relaxed text-muted-foreground/50\">Managed end-to-end web deployment, including VPS configuration, database optimization, and routine system maintenance.</p><div class=\"flex items-center gap-1.5 flex-wrap\"><span class=\"px-1.5 py-0.5 text-[9px] text-tui-cyan/60 bg-tui-cyan/[0.06] rounded-sm\">Linux Server</span><span class=\"px-1.5 py-0.5 text-[9px] text-tui-cyan/60 bg-tui-cyan/[0.06] rounded-sm\">MySQL</span><span class=\"px-1.5 py-0.5 text-[9px] text-tui-cyan/60 bg-tui-cyan/[0.06] rounded-sm\">NGINX</span><span class=\"px-1.5 py-0.5 text-[9px] text-tui-cyan/60 bg-tui-cyan/[0.06] rounded-sm\">Laravel</span></div></div><div class=\"group bg-card p-4 transition-all duration-200 hover:bg-[#1a1a1a]\" style=\"opacity:0;transform:translateY(12px)\"><div class=\"mb-2 flex items-baseline justify-between gap-2\"><h3 class=\"text-sm font-medium text-foreground/80\">IoT &amp; Embedded Systems Developer</h3><span class=\"shrink-0 text-[9px] text-muted-foreground/35 tabular-nums\">2025 — Present</span></div><p class=\"mb-3 text-xs leading-relaxed text-muted-foreground/50\">Designed and built IoT solutions using ESP32 and Arduino platforms. Developed sensor networks, GPS tracking systems, and automated control systems for real-world applications.</p><div class=\"flex items-center gap-1.5 flex-wrap\"><span class=\"px-1.5 py-0.5 text-[9px] text-tui-cyan/60 bg-tui-cyan/[0.06] rounded-sm\">C++</span><span class=\"px-1.5 py-0.5 text-[9px] text-tui-cyan/60 bg-tui-cyan/[0.06] rounded-sm\">ESP32</span><span class=\"px-1.5 py-0.5 text-[9px] text-tui-cyan/60 bg-tui-cyan/[0.06] rounded-sm\">Arduino</span><span class=\"px-1.5 py-0.5 text-[9px] text-tui-cyan/60 bg-tui-cyan/[0.06] rounded-sm\">RTOS</span><span class=\"px-1.5 py-0.5 text-[9px] text-tui-cyan/60 bg-tui-cyan/[0.06] rounded-sm\">IoT</span></div></div><div class=\"group bg-card p-4 transition-all duration-200 hover:bg-[#1a1a1a]\" style=\"opacity:0;transform:translateY(12px)\"><div class=\"mb-2 flex items-baseline justify-between gap-2\"><h3 class=\"text-sm font-medium text-foreground/80\">Full-Stack Web Developer</h3><span class=\"shrink-0 text-[9px] text-muted-foreground/35 tabular-nums\">2025 — Present</span></div><p class=\"mb-3 text-xs leading-relaxed text-muted-foreground/50\">Built and deployed modern web applications using React, Next.js, and TypeScript. Focused on performance, accessibility, and clean architecture.</p><div class=\"flex items-center gap-1.5 flex-wrap\"><span class=\"px-1.5 py-0.5 text-[9px] text-tui-cyan/60 bg-tui-cyan/[0.06] rounded-sm\">React</span><span class=\"px-1.5 py-0.5 text-[9px] text-tui-cyan/60 bg-tui-cyan/[0.06] rounded-sm\">Next.js</span><span class=\"px-1.5 py-0.5 text-[9px] text-tui-cyan/60 bg-tui-cyan/[0.06] rounded-sm\">TypeScript</span><span class=\"px-1.5 py-0.5 text-[9px] text-tui-cyan/60 bg-tui-cyan/[0.06] rounded-sm\">Tailwind CSS</span><span class=\"px-1.5 py-0.5 text-[9px] text-tui-cyan/60 bg-tui-cyan/[0.06] rounded-sm\">Node.js</span></div></div><div class=\"group bg-card p-4 transition-all duration-200 hover:bg-[#1a1a1a]\" style=\"opacity:0;transform:translateY(12px)\"><div class=\"mb-2 flex items-baseline justify-between gap-2\"><h3 class=\"text-sm font-medium text-foreground/80\">Systems Programming &amp; Language Design</h3><span class=\"shrink-0 text-[9px] text-muted-foreground/35 tabular-nums\">2024 — Present</span></div><p class=\"mb-3 text-xs leading-relaxed text-muted-foreground/50\">Developed Sulfur++, a programming language built on LLVM with AOT and JIT compiler pipelines. Explored compiler architecture, code generation, and language design principles.</p><div class=\"flex items-center gap-1.5 flex-wrap\"><span class=\"px-1.5 py-0.5 text-[9px] text-tui-cyan/60 bg-tui-cyan/[0.06] rounded-sm\">C++</span><span class=\"px-1.5 py-0.5 text-[9px] text-tui-cyan/60 bg-tui-cyan/[0.06] rounded-sm\">LLVM</span><span class=\"px-1.5 py-0.5 text-[9px] text-tui-cyan/60 bg-tui-cyan/[0.06] rounded-sm\">Compiler Design</span><span class=\"px-1.5 py-0.5 text-[9px] text-tui-cyan/60 bg-tui-cyan/[0.06] rounded-sm\">Assembly</span></div></div></div></div></div></section><section id=\"sulfur\" class=\"relative section-py\"><div class=\"section-px\"><div class=\"mx-auto max-w-full\"><div style=\"opacity:0;transform:translateY(16px)\"><p class=\"mb-3 text-[10px] text-tui-orange/70 font-medium\">[02] featured project</p><h2 class=\"mb-6 text-2xl font-bold tracking-tight text-foreground\">Sulfur++</h2><p class=\"text-sm leading-relaxed text-muted-foreground/50 max-w-xs\">An interpreted programming language built on the LLVM infrastructure with a JIT compiler pipeline. Designed for systems programming with modern syntax.</p></div><div class=\"mt-8 grid gap-4 sm:grid-cols-2\" style=\"opacity:0;transform:translateY(16px)\"><div class=\"tui-panel p-4\"><div class=\"tui-panel-header\"><span class=\"text-[9px] text-tui-orange/60 font-medium\">The Problem</span></div><p class=\"text-xs leading-relaxed text-muted-foreground/45\">Existing systems languages like C/C++ and Rust have steep learning curves, complex syntax, and error-prone manual memory management. Developers shouldn&#x27;t have to choose between performance and productivity.</p></div><div class=\"tui-panel p-4\"><div class=\"tui-panel-header\"><span class=\"text-[9px] text-tui-green/60 font-medium\">The Solution</span></div><p class=\"text-xs leading-relaxed text-muted-foreground/45\">Sulfur++ combines modern, readable syntax with full systems-level control. Write expressive code that runs fast via LLVM-powered interpretation — getting both developer productivity and near-native performance.</p></div></div><div class=\"mt-8\" style=\"opacity:0;transform:translateY(16px)\"><div class=\"tui-panel-header mb-4\"><span class=\"text-[9px] text-muted-foreground/40\">interpreter pipeline</span></div><div class=\"flex flex-col items-center gap-3 p-4 bg-white/[0.01] border border-white/[0.03] rounded-sm\"><span class=\"text-sm font-medium text-tui-green\">Source Code</span><svg class=\"size-4 text-tui-green/50\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"6 9 12 15 18 9\"></polyline></svg><span class=\"text-sm font-medium text-tui-green\">Lexer</span><svg class=\"size-4 text-tui-green/50\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"6 9 12 15 18 9\"></polyline></svg><span class=\"text-sm font-medium text-tui-green\">Parser</span><svg class=\"size-4 text-tui-green/50\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"6 9 12 15 18 9\"></polyline></svg><span class=\"text-sm font-medium text-tui-green\">Interpreter</span></div></div><div class=\"mt-8\" style=\"opacity:0;transform:translateY(16px)\"><div class=\"tui-panel-header mb-4\"><span class=\"text-[9px] text-muted-foreground/40\">LLVM Backend</span></div><div class=\"grid gap-3 sm:grid-cols-2\"><div class=\"tui-panel p-4 group hover:border-tui-orange/20 transition-colors\" style=\"opacity:0;transform:translateY(8px)\"><h3 class=\"mb-1 text-sm font-bold text-foreground\">LLVM Backend</h3><p class=\"text-xs leading-relaxed text-muted-foreground/45\">Optimized machine code generation</p></div><div class=\"tui-panel p-4 group hover:border-tui-orange/20 transition-colors\" style=\"opacity:0;transform:translateY(8px)\"><h3 class=\"mb-1 text-sm font-bold text-foreground\">JIT Compiler</h3><p class=\"text-xs leading-relaxed text-muted-foreground/45\">Runtime performance optimization</p></div><div class=\"tui-panel p-4 group hover:border-tui-orange/20 transition-colors\" style=\"opacity:0;transform:translateY(8px)\"><h3 class=\"mb-1 text-sm font-bold text-foreground\">Systems-Level</h3><p class=\"text-xs leading-relaxed text-muted-foreground/45\">Manual memory, zero-cost abstractions</p></div></div></div><div class=\"mt-8\" style=\"opacity:0;transform:translateY(16px)\"><div class=\"tui-panel p-4 overflow-x-auto\"><div class=\"tui-panel-header mb-3\"><span class=\"text-[9px] text-muted-foreground/40\">source</span></div><pre class=\"text-[9px] leading-relaxed text-muted-foreground/50 font-mono tabular-nums\">An interpreted programming language built on the LLVM infrastructure with a JIT compiler pipeline. Designed for systems programming with modern syntax.</pre></div></div><div class=\"mt-8 flex justify-center\" style=\"opacity:0;transform:translateY(16px)\"><button type=\"button\" tabindex=\"0\" data-slot=\"button\" class=\"group/button inline-flex shrink-0 items-center justify-center border bg-clip-padding font-medium whitespace-nowrap transition-all outline-none select-none focus-visible:border-ring focus-visible:ring-3 focus-visible:ring-ring/50 active:not-aria-[haspopup]:translate-y-px disabled:pointer-events-none disabled:opacity-50 aria-invalid:border-destructive aria-invalid:ring-3 aria-invalid:ring-destructive/20 dark:aria-invalid:border-destructive/50 dark:aria-invalid:ring-destructive/40 [&amp;_svg]:pointer-events-none [&amp;_svg]:shrink-0 [&amp;_svg:not([class*=&#x27;size-&#x27;])]:size-4 bg-background hover:text-foreground aria-expanded:bg-muted aria-expanded:text-foreground dark:border-input dark:bg-input/30 dark:hover:bg-input/50 h-8 has-data-[icon=inline-end]:pr-2 has-data-[icon=inline-start]:pl-2 group gap-2 px-6 py-3 rounded-sm border-tui-orange/30 text-tui-orange text-xs uppercase tracking-wider hover:bg-tui-orange/10 hover:shadow-[0_0_15px_rgba(249,115,22,0.1)] hover:scale-[1.02] active:scale-[0.98]\">view repository<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-arrow-right size-3.5 transition-transform duration-300 group-hover:translate-x-1\" aria-hidden=\"true\"><path d=\"M5 12h14\"></path><path d=\"m12 5 7 7-7 7\"></path></svg></button></div></div></div></section><section id=\"tech\" class=\"relative section-py\"><div class=\"section-px\"><div class=\"mx-auto max-w-full\"><div class=\"mb-8\" style=\"opacity:0;transform:translateY(12px)\"><p class=\"mb-3 text-[10px] text-tui-cyan/70 font-medium\">[03] capabilities</p><h2 class=\"text-2xl font-bold tracking-tight text-foreground\">Tech Stack</h2></div><div class=\"flex flex-col gap-10\"><div style=\"opacity:0;transform:translateY(16px)\"><div class=\"mb-4 flex items-center gap-2\"><span class=\"text-[9px] text-tui-cyan/40\">01</span><div class=\"h-px flex-1 bg-white/[0.04]\"></div><span class=\"text-[9px] uppercase tracking-wider text-muted-foreground/40\">Low-Level &amp; Embedded Systems</span></div><div class=\"grid grid-cols-2 gap-px bg-white/[0.03]\"><div class=\"group bg-card p-3 transition-all duration-200 hover:bg-[#1a1a1a]\" style=\"opacity:0\"><div class=\"flex items-baseline justify-between\"><span class=\"text-[10px] font-medium text-foreground/60 transition-colors group-hover:text-foreground\">C++</span><span class=\"text-[8px] text-foreground\">■</span></div><span class=\"mt-1 block text-[8px] text-muted-foreground/30 uppercase tracking-wider\">CORE</span></div><div class=\"group bg-card p-3 transition-all duration-200 hover:bg-[#1a1a1a]\" style=\"opacity:0\"><div class=\"flex items-baseline justify-between\"><span class=\"text-[10px] font-medium text-foreground/60 transition-colors group-hover:text-foreground\">ESP32</span><span class=\"text-[8px] text-foreground\">■</span></div><span class=\"mt-1 block text-[8px] text-muted-foreground/30 uppercase tracking-wider\">CORE</span></div><div class=\"group bg-card p-3 transition-all duration-200 hover:bg-[#1a1a1a]\" style=\"opacity:0\"><div class=\"flex items-baseline justify-between\"><span class=\"text-[10px] font-medium text-foreground/60 transition-colors group-hover:text-foreground\">Arduino</span><span class=\"text-[8px] text-foreground\">■</span></div><span class=\"mt-1 block text-[8px] text-muted-foreground/30 uppercase tracking-wider\">CORE</span></div><div class=\"group bg-card p-3 transition-all duration-200 hover:bg-[#1a1a1a]\" style=\"opacity:0\"><div class=\"flex items-baseline justify-between\"><span class=\"text-[10px] font-medium text-foreground/60 transition-colors group-hover:text-foreground\">RTOS</span><span class=\"text-[8px] text-muted-foreground\">◧</span></div><span class=\"mt-1 block text-[8px] text-muted-foreground/30 uppercase tracking-wider\">ADV</span></div></div></div><div style=\"opacity:0;transform:translateY(16px)\"><div class=\"mb-4 flex items-center gap-2\"><span class=\"text-[9px] text-tui-cyan/40\">02</span><div class=\"h-px flex-1 bg-white/[0.04]\"></div><span class=\"text-[9px] uppercase tracking-wider text-muted-foreground/40\">Web &amp; Full-Stack Engineering</span></div><div class=\"grid grid-cols-2 gap-px bg-white/[0.03]\"><div class=\"group bg-card p-3 transition-all duration-200 hover:bg-[#1a1a1a]\" style=\"opacity:0\"><div class=\"flex items-baseline justify-between\"><span class=\"text-[10px] font-medium text-foreground/60 transition-colors group-hover:text-foreground\">React.js</span><span class=\"text-[8px] text-foreground\">■</span></div><span class=\"mt-1 block text-[8px] text-muted-foreground/30 uppercase tracking-wider\">CORE</span></div><div class=\"group bg-card p-3 transition-all duration-200 hover:bg-[#1a1a1a]\" style=\"opacity:0\"><div class=\"flex items-baseline justify-between\"><span class=\"text-[10px] font-medium text-foreground/60 transition-colors group-hover:text-foreground\">TypeScript</span><span class=\"text-[8px] text-foreground\">■</span></div><span class=\"mt-1 block text-[8px] text-muted-foreground/30 uppercase tracking-wider\">CORE</span></div><div class=\"group bg-card p-3 transition-all duration-200 hover:bg-[#1a1a1a]\" style=\"opacity:0\"><div class=\"flex items-baseline justify-between\"><span class=\"text-[10px] font-medium text-foreground/60 transition-colors group-hover:text-foreground\">JavaScript</span><span class=\"text-[8px] text-foreground\">■</span></div><span class=\"mt-1 block text-[8px] text-muted-foreground/30 uppercase tracking-wider\">CORE</span></div><div class=\"group bg-card p-3 transition-all duration-200 hover:bg-[#1a1a1a]\" style=\"opacity:0\"><div class=\"flex items-baseline justify-between\"><span class=\"text-[10px] font-medium text-foreground/60 transition-colors group-hover:text-foreground\">Next.js</span><span class=\"text-[8px] text-muted-foreground\">◧</span></div><span class=\"mt-1 block text-[8px] text-muted-foreground/30 uppercase tracking-wider\">ADV</span></div><div class=\"group bg-card p-3 transition-all duration-200 hover:bg-[#1a1a1a]\" style=\"opacity:0\"><div class=\"flex items-baseline justify-between\"><span class=\"text-[10px] font-medium text-foreground/60 transition-colors group-hover:text-foreground\">Tailwind CSS</span><span class=\"text-[8px] text-foreground\">■</span></div><span class=\"mt-1 block text-[8px] text-muted-foreground/30 uppercase tracking-wider\">CORE</span></div><div class=\"group bg-card p-3 transition-all duration-200 hover:bg-[#1a1a1a]\" style=\"opacity:0\"><div class=\"flex items-baseline justify-between\"><span class=\"text-[10px] font-medium text-foreground/60 transition-colors group-hover:text-foreground\">Python</span><span class=\"text-[8px] text-muted-foreground\">◧</span></div><span class=\"mt-1 block text-[8px] text-muted-foreground/30 uppercase tracking-wider\">ADV</span></div><div class=\"group bg-card p-3 transition-all duration-200 hover:bg-[#1a1a1a]\" style=\"opacity:0\"><div class=\"flex items-baseline justify-between\"><span class=\"text-[10px] font-medium text-foreground/60 transition-colors group-hover:text-foreground\">PHP</span><span class=\"text-[8px] text-muted-foreground\">◧</span></div><span class=\"mt-1 block text-[8px] text-muted-foreground/30 uppercase tracking-wider\">ADV</span></div><div class=\"group bg-card p-3 transition-all duration-200 hover:bg-[#1a1a1a]\" style=\"opacity:0\"><div class=\"flex items-baseline justify-between\"><span class=\"text-[10px] font-medium text-foreground/60 transition-colors group-hover:text-foreground\">Laravel</span><span class=\"text-[8px] text-muted-foreground\">◧</span></div><span class=\"mt-1 block text-[8px] text-muted-foreground/30 uppercase tracking-wider\">ADV</span></div></div></div></div><div class=\"mt-8 flex flex-wrap items-center gap-3 border-t border-white/[0.04] pt-5\" style=\"opacity:0\"><span class=\"text-[9px] text-muted-foreground/30 uppercase tracking-wider\">legend</span><div class=\"flex items-center gap-1\"><span class=\"text-[9px] text-foreground\">■</span><span class=\"text-[9px] text-muted-foreground/30 uppercase tracking-wider\">CORE</span></div><div class=\"flex items-center gap-1\"><span class=\"text-[9px] text-muted-foreground\">◧</span><span class=\"text-[9px] text-muted-foreground/30 uppercase tracking-wider\">ADV</span></div><div class=\"flex items-center gap-1\"><span class=\"text-[9px] text-tui-cyan\">□</span><span class=\"text-[9px] text-muted-foreground/30 uppercase tracking-wider\">LRN</span></div></div></div></div></section><section id=\"infra\" class=\"relative section-py\"><div class=\"section-px\"><div class=\"mx-auto max-w-full\"><div class=\"mb-8\" style=\"opacity:0;transform:translateY(12px)\"><p class=\"mb-3 text-[10px] text-tui-cyan/70 font-medium\">[04] infrastructure</p><h2 class=\"text-2xl font-bold tracking-tight text-foreground\">Infrastructure &amp; Tooling</h2></div><div class=\"tui-panel mb-4\" style=\"opacity:0;transform:translateY(16px)\"><div class=\"tui-panel-header\"><span class=\"text-[9px] text-tui-cyan/60\">Environment</span></div><div class=\"p-4\"><p class=\"mb-4 text-xs leading-relaxed text-muted-foreground/45\">Experienced with Linux server administration across Ubuntu/Debian distributions. Comfortable with command-line environments, systemd services, and shell scripting for automation.</p><div class=\"space-y-2\"><div class=\"p-3 bg-white/[0.02] border border-white/[0.03] transition-colors hover:bg-white/[0.05]\" style=\"opacity:0\"><p class=\"text-[11px] font-medium text-foreground/70\">Ubuntu/Debian</p><p class=\"mt-1 text-[9px] text-muted-foreground/35\">Primary server OS</p></div><div class=\"p-3 bg-white/[0.02] border border-white/[0.03] transition-colors hover:bg-white/[0.05]\" style=\"opacity:0\"><p class=\"text-[11px] font-medium text-foreground/70\">Bash/Zsh</p><p class=\"mt-1 text-[9px] text-muted-foreground/35\">Shell scripting &amp; automation</p></div><div class=\"p-3 bg-white/[0.02] border border-white/[0.03] transition-colors hover:bg-white/[0.05]\" style=\"opacity:0\"><p class=\"text-[11px] font-medium text-foreground/70\">systemd</p><p class=\"mt-1 text-[9px] text-muted-foreground/35\">Service management</p></div><div class=\"p-3 bg-white/[0.02] border border-white/[0.03] transition-colors hover:bg-white/[0.05]\" style=\"opacity:0\"><p class=\"text-[11px] font-medium text-foreground/70\">Git</p><p class=\"mt-1 text-[9px] text-muted-foreground/35\">Version control &amp; CI/CD</p></div></div></div></div><div class=\"tui-panel\" style=\"opacity:0;transform:translateY(16px)\"><div class=\"tui-panel-header\"><span class=\"text-[9px] text-tui-orange/60\">Tools &amp; Services</span></div><div class=\"p-4\"><p class=\"mb-4 text-xs leading-relaxed text-muted-foreground/45\">Hands-on experience managing production VPS environments, configuring web servers, databases, and implementing security best practices.</p><div class=\"space-y-3\"><div class=\"flex items-start gap-2\" style=\"opacity:0;transform:translateX(-6px)\"><span class=\"mt-0.5 text-tui-orange/60 text-[10px]\">+</span><div><p class=\"text-[11px] font-medium text-foreground/70\">NGINX</p><p class=\"text-[9px] text-muted-foreground/40\">Reverse proxy &amp; static serving</p></div></div><div class=\"flex items-start gap-2\" style=\"opacity:0;transform:translateX(-6px)\"><span class=\"mt-0.5 text-tui-orange/60 text-[10px]\">+</span><div><p class=\"text-[11px] font-medium text-foreground/70\">MySQL</p><p class=\"text-[9px] text-muted-foreground/40\">Database management &amp; optimization</p></div></div><div class=\"flex items-start gap-2\" style=\"opacity:0;transform:translateX(-6px)\"><span class=\"mt-0.5 text-tui-orange/60 text-[10px]\">+</span><div><p class=\"text-[11px] font-medium text-foreground/70\">SSH</p><p class=\"text-[9px] text-muted-foreground/40\">Remote access &amp; key management</p></div></div><div class=\"flex items-start gap-2\" style=\"opacity:0;transform:translateX(-6px)\"><span class=\"mt-0.5 text-tui-orange/60 text-[10px]\">+</span><div><p class=\"text-[11px] font-medium text-foreground/70\">VPS Management</p><p class=\"text-[9px] text-muted-foreground/40\">Deployment, monitoring &amp; scaling</p></div></div><div class=\"flex items-start gap-2\" style=\"opacity:0;transform:translateX(-6px)\"><span class=\"mt-0.5 text-tui-orange/60 text-[10px]\">+</span><div><p class=\"text-[11px] font-medium text-foreground/70\">Docker</p><p class=\"text-[9px] text-muted-foreground/40\">Containerized deployments</p></div></div><div class=\"flex items-start gap-2\" style=\"opacity:0;transform:translateX(-6px)\"><span class=\"mt-0.5 text-tui-orange/60 text-[10px]\">+</span><div><p class=\"text-[11px] font-medium text-foreground/70\">Let&#x27;s Encrypt</p><p class=\"text-[9px] text-muted-foreground/40\">SSL/TLS certificate management</p></div></div></div></div></div></div></div></section><section id=\"projects\" class=\"relative section-py\"><div class=\"section-px\"><div class=\"mx-auto max-w-full\"><div class=\"mb-8\" style=\"opacity:0;transform:translateY(12px)\"><p class=\"mb-3 text-[10px] text-tui-cyan/70 font-medium\">[05] work</p><h2 class=\"text-2xl font-bold tracking-tight text-foreground\">Top 3 Projects</h2></div><div class=\"flex flex-col gap-4\"><div class=\"group relative border border-tui-cyan/30 bg-tui-cyan/[0.04] hover:shadow-[0_0_20px_rgba(6,182,212,0.06)] transition-all duration-300\" style=\"opacity:0;transform:translateY(16px)\"><div class=\"absolute top-0 left-0 w-2 h-2 border-t border-l border-tui-cyan/30\"></div><div class=\"absolute top-0 right-0 w-2 h-2 border-t border-r border-tui-cyan/30\"></div><d